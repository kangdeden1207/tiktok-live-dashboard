# ====== SERVER ======
PORT=3000

# ====== MODE ======
# "simulation" = pakai data dummy (default, aman buat development)
# "live"       = coba connect ke room TikTok asli via tiktok-live-connector
TIKTOK_MODE=simulation

# ====== REDIS (state cepat: viewer count, cache komentar, dsb) ======
REDIS_URL=redis://127.0.0.1:6379

# ====== SUPABASE (persistent data: log gift, log order, history sesi) ======
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
